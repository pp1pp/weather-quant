# Safe default: run in dry-run mode until you have validated the strategy.
LIVE_TRADING=false

# Polymarket / CLOB credentials for live mode.
PRIVATE_KEY=
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# Optional settlement / funding address used by some account setups.
FUNDER=

# Dashboard password (HTTP Basic Auth). Leave empty for no auth (local dev).
DASHBOARD_PASSWORD=

# Server port. Railway injects this automatically; defaults to 8000.
# PORT=8000
